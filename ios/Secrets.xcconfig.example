// DateNight Secrets Configuration
//
// Copy this file to Secrets.xcconfig and add your actual API keys.
// Secrets.xcconfig is gitignored to keep your keys safe.

// Option 1: Direct Anthropic API Key (Simpler, for development)
// Get your key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY =

// Option 2: AIProxy (More secure, for production)
// Get your credentials from: https://aiproxy.pro/dashboard
AIPROXY_PARTIAL_KEY =
AIPROXY_SERVICE_URL =

// DeviceCheck bypass for iOS Simulator (required for AIProxy in simulator)
AIPROXY_DEVICE_CHECK_BYPASS = your-bypass-token-here
