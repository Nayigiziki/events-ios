default_platform(:ios)

platform :ios do
  # =============================================================================
  # Helpers
  # =============================================================================

  private_lane :load_env do
    require 'dotenv'
    Dotenv.load("../.env") if File.exist?("../.env")
  end

  private_lane :get_api_key_path do
    key_id = ENV["FASTLANE_KEY_ID"] || ENV["APP_STORE_CONNECT_API_KEY_ID"] || ENV["APP_STORE_CONNECT_KEY_ID"]
    paths = [
      File.expand_path("~/.appstoreconnect/private_keys/AuthKey_#{key_id}.p8"),
      File.expand_path("~/.private_keys/AuthKey_#{key_id}.p8"),
      ENV["ASC_KEY_FILEPATH"],
    ].compact

    path = paths.find { |p| File.exist?(p) }
    UI.user_error!("API key .p8 file not found. Searched:\n  #{paths.join("\n  ")}") unless path
    path
  end

  # =============================================================================
  # TestFlight Deployment
  # =============================================================================

  desc "Build and upload to TestFlight"
  lane :deploy_testflight do
    load_env

    team_id = ENV["APPLE_TEAM_ID"]
    UI.user_error!("APPLE_TEAM_ID not set") unless team_id && !team_id.empty?

    api_key_path = get_api_key_path
    UI.message("Found API key at: #{api_key_path}")

    ios_dir = File.expand_path("..", __dir__)
    build_dir = File.join(ios_dir, "build")
    archive_path = File.join(build_dir, "DateNight.xcarchive")
    FileUtils.mkdir_p(build_dir)

    key_id = ENV["FASTLANE_KEY_ID"] || ENV["APP_STORE_CONNECT_API_KEY_ID"]
    issuer_id = ENV["FASTLANE_ISSUER_ID"] || ENV["APP_STORE_CONNECT_ISSUER_ID"]
    UI.user_error!("FASTLANE_KEY_ID not set") unless key_id && !key_id.empty?
    UI.user_error!("FASTLANE_ISSUER_ID not set") unless issuer_id && !issuer_id.empty?

    api_key = app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_filepath: api_key_path,
      duration: 1200,
      in_house: false
    )

    # Step 1: Get provisioning profile (automatic signing)
    UI.message("\nStep 1: Getting provisioning profile...")
    get_provisioning_profile(
      app_identifier: "com.tron.datenight",
      api_key: api_key,
      readonly: false,
      adhoc: false,
      skip_install: false
    )
    UI.success("Provisioning profile ready")

    # Step 2: Increment build number
    UI.message("\nStep 2: Incrementing build number...")
    build_number = increment_build_number(
      xcodeproj: "#{ios_dir}/DateNight.xcodeproj"
    )
    UI.message("New build number: #{build_number}")

    # Step 3: Build and archive
    UI.message("\nStep 3: Building and archiving...")
    build_app(
      scheme: "DateNight",
      project: "#{ios_dir}/DateNight.xcodeproj",
      configuration: "Release",
      output_directory: build_dir,
      output_name: "DateNight",
      archive_path: archive_path,
      export_method: "app-store",
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        teamID: team_id,
        provisioningProfiles: {
          "com.tron.datenight" => "com.tron.datenight AppStore"
        }
      },
      xcargs: "DEVELOPMENT_TEAM=#{team_id} -allowProvisioningUpdates -authenticationKeyPath '#{api_key_path}' -authenticationKeyID #{key_id} -authenticationKeyIssuerID #{issuer_id}"
    )
    UI.success("Archive created successfully")

    # Step 4: Upload to TestFlight
    UI.message("\nStep 4: Uploading to TestFlight...")
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      changelog: "Beta build",
      distribute_external: false,
      notify_external_testers: false
    )

    UI.success("🚀 Build uploaded to TestFlight!")
  end

  # =============================================================================
  # Utility Lanes
  # =============================================================================

  desc "Run SwiftLint"
  lane :lint do
    sh("cd .. && swiftlint lint --strict --config ../.swiftlint.yml")
  end

  desc "Print current version"
  lane :version do
    ios_dir = File.expand_path("..", __dir__)
    version = get_version_number(xcodeproj: "#{ios_dir}/DateNight.xcodeproj")
    build = get_build_number(xcodeproj: "#{ios_dir}/DateNight.xcodeproj")
    UI.message("Version: #{version} (#{build})")
  end
end
