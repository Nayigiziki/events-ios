/* Help FAQ */
"help_faq_create_date_q" = "Como creo una cita?";
"help_faq_create_date_a" = "Explora eventos o matches, luego toca 'Invitar a una Cita' en cualquier perfil o evento. Elige una hora, agrega un mensaje y envia la invitacion. Tu match recibira una notificacion para aceptar o rechazar.";
"help_faq_matching_q" = "Como funciona el matching?";
"help_faq_matching_a" = "Te emparejamos basandonos en intereses y preferencias de eventos compartidos. Desliza a la derecha en los perfiles que te gusten. Cuando ambos deslicen a la derecha, es un match! Luego pueden chatear y planificar citas juntos.";
"help_faq_friends_q" = "Como agrego amigos?";
"help_faq_friends_a" = "Ve a la pestana de Amigos y toca el boton '+'. Puedes buscar personas por nombre o invitar amigos usando su correo electronico. Los amigos pueden ver tus eventos y unirse a citas grupales.";
"help_faq_report_q" = "Como reporto a alguien?";
"help_faq_report_a" = "Abre el perfil del usuario y toca el menu '...' en la esquina superior derecha. Selecciona 'Reportar Usuario' y elige una razon. Nuestro equipo de seguridad revisa todos los reportes en 24 horas.";
"help_faq_delete_q" = "Como elimino mi cuenta?";
"help_faq_delete_a" = "Ve a Configuracion > Zona de Peligro > Eliminar Cuenta. Esto eliminara permanentemente tu perfil, matches, mensajes y todos los datos asociados. Esta accion no se puede deshacer.";
